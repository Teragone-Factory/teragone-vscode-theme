  "semanticTokenColors": {
    "comment": { "foreground": "#7A6E5E", "fontStyle": "italic" },
    "string": "#7AAE89",
    "number": "#E5B062",
    "boolean": { "foreground": "#F2A075", "bold": true },
    "regexp": "#A2B58A",
    "operator": "#998A77",
    "keyword": "#E07A4F",
    "modifier": "#F2A075",
    "type": { "foreground": "#E8DDC9", "bold": true },
    "class": { "foreground": "#E8DDC9", "bold": true },
    "interface": "#A2B58A",
    "enum": "#F2A075",
    "enumMember": "#E5B062",
    "struct": { "foreground": "#E8DDC9", "bold": true },
    "typeParameter": "#A2B58A",
    "namespace": "#E8DDC9",
    "function": "#E07A4F",
    "method": "#E07A4F",
    "decorator": { "foreground": "#E07A4F", "italic": true },
    "macro": "#F2A075",
    "label": "#F2A075",
    "variable": "#E8DDC9",
    "variable.readonly": "#E5B062",
    "variable.defaultLibrary": { "foreground": "#F2A075", "italic": true },
    "parameter": { "foreground": "#998A77", "italic": true },
    "property": "#E8DDC9",
    "property.readonly": "#E5B062",
    "property.declaration": "#F2A075",
    "event": "#E07A4F",
    "selfParameter": { "foreground": "#F2A075", "italic": true },
    "builtinAttribute": { "foreground": "#F2A075", "italic": true },
    "attribute": { "foreground": "#E5B062", "italic": true },
    "*.deprecated": { "strikethrough": true },
    "*.abstract": { "italic": true },
    "*.async": { "italic": true }
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment", "string.comment"],
      "settings": { "foreground": "#7A6E5E", "fontStyle": "italic" }
    },
    {
      "scope": ["string", "string.quoted", "string.template", "punctuation.definition.string"],
      "settings": { "foreground": "#7AAE89" }
    },
    {
      "scope": ["string.regexp", "constant.regexp"],
      "settings": { "foreground": "#A2B58A" }
    },
    {
      "scope": ["constant.numeric", "constant.numeric.integer", "constant.numeric.float"],
      "settings": { "foreground": "#E5B062" }
    },
    {
      "scope": ["constant.language", "constant.language.boolean", "constant.language.null"],
      "settings": { "foreground": "#F2A075", "fontStyle": "bold" }
    },
    {
      "scope": ["constant.character", "constant.other", "constant.character.escape"],
      "settings": { "foreground": "#E5B062" }
    },
    {
      "scope": ["keyword", "keyword.control", "keyword.operator.new", "keyword.operator.expression"],
      "settings": { "foreground": "#E07A4F" }
    },
    {
      "scope": ["keyword.operator", "keyword.operator.logical", "keyword.operator.comparison", "keyword.operator.arithmetic", "keyword.operator.assignment"],
      "settings": { "foreground": "#998A77" }
    },
    {
      "scope": ["storage", "storage.type", "storage.modifier", "keyword.declaration"],
      "settings": { "foreground": "#F2A075" }
    },
    {
      "scope": ["entity.name.function", "support.function", "meta.function-call.generic", "variable.function"],
      "settings": { "foreground": "#E07A4F" }
    },
    {
      "scope": ["entity.name.class", "entity.name.type", "entity.name.type.class", "entity.other.inherited-class", "support.class", "support.type"],
      "settings": { "foreground": "#E8DDC9", "fontStyle": "bold" }
    },
    {
      "scope": ["entity.name.tag", "entity.name.tag.html", "entity.name.tag.xml"],
      "settings": { "foreground": "#F2A075" }
    },
    {
      "scope": ["entity.other.attribute-name", "entity.other.attribute-name.html"],
      "settings": { "foreground": "#E5B062", "fontStyle": "italic" }
    },
    {
      "scope": ["variable", "variable.other", "variable.other.readwrite"],
      "settings": { "foreground": "#E8DDC9" }
    },
    {
      "scope": ["variable.parameter", "variable.parameter.function"],
      "settings": { "foreground": "#998A77", "fontStyle": "italic" }
    },
    {
      "scope": ["variable.language", "variable.language.self", "variable.language.this"],
      "settings": { "foreground": "#F2A075", "fontStyle": "italic" }
    },
    {
      "scope": ["support.variable", "support.constant"],
      "settings": { "foreground": "#F2A075" }
    },
    {
      "scope": ["meta.decorator", "entity.name.function.decorator", "punctuation.decorator"],
      "settings": { "foreground": "#E07A4F", "fontStyle": "italic" }
    },
    {
      "scope": ["punctuation", "punctuation.definition", "punctuation.separator", "punctuation.terminator"],
      "settings": { "foreground": "#998A77" }
    },
    {
      "scope": ["punctuation.section.embedded", "punctuation.section.embedded.begin", "punctuation.section.embedded.end"],
      "settings": { "foreground": "#E07A4F" }
    },
    {
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#E5705A", "fontStyle": "bold underline" }
    },
    {
      "scope": ["invalid.deprecated"],
      "settings": { "foreground": "#7A6E5E", "fontStyle": "strikethrough" }
    },

    {
      "scope": ["markup.heading", "markup.heading.markdown", "entity.name.section.markdown", "punctuation.definition.heading.markdown"],
      "settings": { "foreground": "#E8DDC9", "fontStyle": "bold" }
    },
    {
      "scope": ["markup.heading.1"],
      "settings": { "foreground": "#E8DDC9", "fontStyle": "bold" }
    },
    {
      "scope": ["markup.heading.2"],
      "settings": { "foreground": "#F2A075", "fontStyle": "bold" }
    },
    {
      "scope": ["markup.heading.3"],
      "settings": { "foreground": "#E07A4F", "fontStyle": "bold" }
    },
    {
      "scope": ["markup.bold", "markup.bold.markdown", "punctuation.definition.bold.markdown"],
      "settings": { "foreground": "#E8DDC9", "fontStyle": "bold" }
    },
    {
      "scope": ["markup.italic", "markup.italic.markdown", "punctuation.definition.italic.markdown"],
      "settings": { "foreground": "#E07A4F", "fontStyle": "italic" }
